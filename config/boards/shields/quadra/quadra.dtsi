#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/pinctrl/nrf-pinctrl.h>

/ {
    chosen {
        // ↓ 衝突を避けるため、独自のラベル名「kscan_quadra」を指定します
        zmk,kscan = &kscan_quadra;
        zmk,underglow = &led_strip;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <6>;
        rows = <4>;
        map = <
            /* ROW 0 */
            RC(4,3) RC(3,4) RC(5,3) RC(3,5)         RC(3,6)
            /* ROW 1 */
            RC(4,2) RC(2,4) RC(5,2) RC(2,5)         RC(2,6)
            /* ROW 2 */
            RC(4,1) RC(1,4) RC(5,1) RC(1,5) RC(6,1) RC(1,6)
            /* ROW 3 */
            RC(4,0) RC(0,4) RC(5,0) RC(0,5) RC(6,0) RC(0,6)
        >;
    };

    /* 
     * ノードの名前を「kscan」から「kscan_quadra」に変更して衝突を回避。
     * columns や rows は書かない（ドライバの本来の仕様通り）。
     */
    kscan_quadra: kscan_quadra {
        compatible = "zmk,kscan-gpio-charlieplex";
        wakeup-source;

        gpios
            = <&xiao_d 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
    };
};


/* LED (SK6812MINI) 用に SPI1 の MOSI ピンを D4 (P0.29) に再定義 */
&pinctrl {
    spi1_default: spi1_default {
        group1 {
            psels = <NRF_PSEL(SPIM_MOSI, 0, 29)>;
        };
    };
    spi1_sleep: spi1_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_MOSI, 0, 29)>;
            low-power-enable;
        };
    };
};

&spi1 {
    compatible = "nordic,nrf-spim";
    status = "okay";
    pinctrl-0 = <&spi1_default>;
    pinctrl-1 = <&spi1_sleep>;
    pinctrl-names = "default", "sleep";

    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";
        reg = <0>;
        spi-max-frequency = <4000000>;
        chain-length = <22>;
        spi-one-frame = <0x70>;
        spi-zero-frame = <0x40>;
        color-mapping = <3 2 1>; /* GRB カラーマッピング */
    };
};
