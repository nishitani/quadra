#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/rgb.h>

/ {
    chosen {
        /* キーマップ側でもデフォルトのトランスフォームとして紐付けます */
        zmk,matrix-transform = &default_transform;
    };
    
    keymap {
        compatible = "zmk,keymap";

        /*
         * レイヤー 0: デフォルト (右手キーマップ)
         * キー数: 22 (5 + 5 + 6 + 6)
         * トランスフォームの記述順 (SWxxx) に正確に対応させる必要があります。
         */
        default_layer {
            bindings = <
                /* =========================================================
                【kscan_a】通常スキャン（上側ボタン）
                1列目(C0), 2列目(C1), 3列目(C2)
                ========================================================= */
                &kp U      &kp Y      &kp BSPC  /* 行0（回路図 SW000, SW010, SW020）*/
                &kp O      &kp I      &kp P     /* 行1（回路図 SW100, SW110, SW120）*/
                &kp J      &kp K      &kp L     /* 行2（回路図 SW200, SW210, SW220）*/
                &kp H      &kp N      &kp M     /* 行3（回路図 SW300, SW310, SW320）*/

                /* =========================================================
                【kscan_b】逆方向スキャン（下側ボタン）
                1列目(C0), 2列目(C1), 3列目(C2)
                ========================================================= */
                &kp COMMA  &kp DOT    &kp SLASH /* 行4（回路図 SW001, SW011, SW021）*/
                &kp ENTER  &kp SPACE  &kp RGUI  /* 行5（回路図 SW101, SW111, SW121）*/
                &kp Q      &kp W      &kp E     /* 行6（回路図 SW201, SW211, SW221）*/
                &kp A      &kp S      &kp D     /* 行7（予備・回路図上は使わない）*/
            >;
        };

        /*
         * レイヤー 1: LEDコントロール & 設定
         */
        lower_layer {
            bindings = <
                /* ROW 0: RGBトグル, RGBエフェクト切替, 輝度アップ, 輝度ダウン, なし */
                &rgb_ug RGB_TOG &rgb_ug RGB_EFF &rgb_ug RGB_BRI &rgb_ug RGB_BRD &none
                /* ROW 1 */
                &none           &none           &none           &none           &none
                /* ROW 2 */
                &none           &none           &none           &none           &none     &none
                /* ROW 3 */
                &trans          &none           &none           &none           &none     &none
            >;
        };
    };
};
